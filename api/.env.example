DATABASE_URL=postgresql://postgres:password@localhost:5432/octree
PORT=3001
NODE_ENV=development

# Redis — backs the BullMQ submission queue (the @octree/worker package
# consumes it and runs code on Judge0)
REDIS_URL=redis://localhost:6379

# The single browser origin allowed for credentialed CORS + Socket.IO. Cookies
# require an explicit origin (not "*"). Point this at the web app.
WEB_ORIGIN=http://localhost:5173

# ── Auth / sessions ──────────────────────────────────────────────────────────
# How long a login session lasts (sliding expiration).
SESSION_TTL_DAYS=30
# Cookie flags. secure defaults to true in production; SameSite=Lax works for
# the same-site web↔api split. Set COOKIE_SAMESITE=none (+ secure) if the web
# and API are on genuinely cross-site domains.
# COOKIE_SECURE=false
# COOKIE_SAMESITE=lax

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create a Web OAuth client at https://console.cloud.google.com → Credentials.
# Authorized redirect URI must exactly match GOOGLE_REDIRECT_URI below.
# Email/password auth works without these; the Google button 501s until set.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Optional: length of each problem round in seconds for the realtime room
# timer. Leave unset to use each room's own durationMinutes. Set something
# small (e.g. 60) to watch problems rotate.
# ROUND_SECONDS=60
