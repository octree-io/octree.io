# Port the mock listens on. Match the worker's JUDGE0_URL (default 2358).
PORT=2358

# How many GET /submissions/:token polls return a non-terminal "Processing"
# status before the result becomes terminal. Set 0 to be terminal immediately.
MOCK_PROCESSING_POLLS=1

# Fixed verdict every submission resolves to, so you can exercise non-happy
# paths. One of: accepted | wrong_answer | tle | compile_error | runtime_error.
# Default "auto": Accepted, echoing expected_output as stdout (so checks pass).
MOCK_VERDICT=auto

# If set, requests must carry this token in the X-Auth-Token header (mirrors a
# Judge0 instance with authn enabled). Leave unset to disable auth.
# JUDGE0_AUTH_TOKEN=
